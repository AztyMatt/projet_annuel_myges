### App version used to tag Docker images (e.g. 1.0.0, latest)
APP_VERSION=latest

### PostgreSQL
POSTGRES_DB=mygesdb
POSTGRES_USER=mygesuser
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

### Ports
# PROD (Port exposed for the nginx reverse proxy)
HTTP_PORT=80
# DEV (Internal ports)
BACKEND_PORT=3001
FRONTEND_PORT=3000