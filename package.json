{
    "name": "projet_annuel_myges",
    "version": "1.0.0",
    "description": "",
    "private": true,
    "_moduleAliases": {
        "@express": "infrastructure/backend/express/dist",
        "@application": "infrastructure/application",
        "@domain": "infrastructure/domain"
    },
    "workspaces": [
        "domain",
        "application",
        "infrastructure/*",
        "infrastructure/backend/express",
        "infrastructure/frontend/next"
    ],
    "scripts": {
        "dev:express": "npm run dev --workspace=@myges/express",
        "build:express": "npm run build --workspace=@myges/express",
        "start:express": "npm run start --workspace=@myges/express",
        "dev:next": "npm run dev --workspace=@myges/next",
        "start:next": "npm run start --workspace=@myges/next",
        "db:generate": "npm run db:generate --workspace=@myges/express",
        "db:migrate": "npm run db:migrate --workspace=@myges/express",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yaml,yml}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ludovicMAK/projet_annuel_myges.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/ludovicMAK/projet_annuel_myges/issues"
    },
    "homepage": "https://github.com/ludovicMAK/projet_annuel_myges#readme",
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@types/supertest": "^7.2.1",
        "dotenv": "^17.4.2",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.19.3",
        "typescript": "^6.0.2",
        "vitest": "^4.1.10"
    }
}
