{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",            // Indique où est ton code source
    "outDir": "./dist",            // Où le code compilé ira
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,                // Important pour la qualité du code
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {                     // Optionnel : pour des imports plus propres
      "@domain/*": ["src/domain/*"],
      "@application/*": ["src/application/*"],
      "@infrastructure/*": ["src/infrastructure/*"]
    }
  },
  "include": ["src/**/*"],         // Compile tout ce qui est dans src
  "exclude": ["node_modules", "**/*.test.ts"]
}